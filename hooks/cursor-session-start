#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
export CURSOR_PLUGIN_ROOT="${CURSOR_PLUGIN_ROOT:-$PLUGIN_ROOT}"
export CLAUDE_PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$PLUGIN_ROOT}"

output=""
for script in \
  "$PLUGIN_ROOT/scripts/session-start-load-state.sh" \
  "$PLUGIN_ROOT/scripts/session-start-autopilot.sh"; do
  if [[ -x "$script" ]]; then
    result="$("$script" 2>/dev/null || true)"
    if [[ -n "$result" ]]; then
      output="${output}${result}"$'\n'
    fi
  fi
done

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

escaped="$(escape_for_json "$output")"
printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
exit 0
